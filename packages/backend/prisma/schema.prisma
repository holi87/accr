generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(OPERATOR)
  notes     Note[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  ADMIN
  OPERATOR
}

model Section {
  id          Int        @id @default(autoincrement())
  slug        String     @unique
  title       String
  description String?
  order       Int
  questions   Question[]
}

model Question {
  id          Int       @id @default(autoincrement())
  sectionId   Int
  section     Section   @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  fieldKey    String    @unique
  label       String    @db.Text
  helpText    String?   @db.Text
  type        FieldType
  required    Boolean   @default(true)
  options     Json?
  order       Int
  isConsent   Boolean   @default(false)
  consentText String?   @db.Text
  enabled     Boolean   @default(true)
  showWhen    Json?
  answers     Answer[]

  @@index([sectionId])
}

enum FieldType {
  TEXT
  TEXTAREA
  EMAIL
  PHONE
  SELECT
  MULTI_SELECT
  RADIO
  CHECKBOX
  CHECKBOX_CONSENT
}

model Submission {
  id              Int      @id @default(autoincrement())
  trackingToken   String   @unique @default(uuid())
  applicationType Json
  entityType      String
  status          Status   @default(NOWE)
  statusHistory   StatusChange[]
  iterationCount  Int      @default(0)
  answers         Answer[]
  notes           Note[]
  emails          EmailLog[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([trackingToken])
}

enum Status {
  NOWE
  WERYFIKACJA_KOMPLETNOSCI
  OCZEKIWANIE_NA_PLATNOSC
  W_RECENZJI
  OCZEKIWANIE_NA_POPRAWKI
  PONOWNA_RECENZJA
  ZAAKCEPTOWANE
  ODRZUCONE
}

model StatusChange {
  id           Int        @id @default(autoincrement())
  submissionId Int
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  fromStatus   String
  toStatus     String
  comment      String?    @db.Text
  createdAt    DateTime   @default(now())

  @@index([submissionId])
}

model Answer {
  id           Int        @id @default(autoincrement())
  submissionId Int
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  questionId   Int
  question     Question   @relation(fields: [questionId], references: [id])
  value        String     @db.Text

  @@index([submissionId])
  @@unique([submissionId, questionId])
}

model Note {
  id           Int        @id @default(autoincrement())
  submissionId Int
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  authorId     Int
  author       User       @relation(fields: [authorId], references: [id])
  content      String     @db.Text
  createdAt    DateTime   @default(now())
}

model EmailLog {
  id           Int         @id @default(autoincrement())
  submissionId Int?
  submission   Submission? @relation(fields: [submissionId], references: [id])
  toAddress    String
  subject      String
  body         String      @db.Text
  status       String
  errorMessage String?
  sentAt       DateTime    @default(now())
}

model Setting {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String @db.Text
}
