{
  "name": "sjsi-accreditation",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/backend",
    "packages/frontend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w packages/backend\" \"npm run dev -w packages/frontend\"",
    "build": "npm run build -w packages/backend && npm run build -w packages/frontend",
    "test": "npm test -w packages/backend",
    "db:migrate": "npx prisma migrate dev --schema=packages/backend/prisma/schema.prisma",
    "db:seed": "npx prisma db seed --schema=packages/backend/prisma/schema.prisma",
    "db:generate": "npx prisma generate --schema=packages/backend/prisma/schema.prisma"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "^5.7.3"
  }
}
